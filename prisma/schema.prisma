generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Table {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  ratePerMin Float
  sessions   Session[]
  sectionAssignments TableSectionAssignment[]

  @@map("tables")
}

model TableSection {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assignments TableSectionAssignment[]

  @@map("table_sections")
}

model TableSectionAssignment {
  id        Int @id @default(autoincrement())
  tableId   Int @unique
  sectionId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  table   Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  section TableSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("table_section_assignments")
}

model Session {
  id        Int         @id @default(autoincrement())
  tableId   Int
  businessDayKey String?
  playerName String
  payerMode PayerMode   @default(none)
  payerData Json?
  overridePayerMode String?
  overridePayerData Json?
  overrideStatus String?
  overridePaymentModes Json?
  startTime DateTime
  endTime   DateTime?
  overrideStartTime DateTime?
  overrideEndTime DateTime?
  overrideRatePerMin Int?
  status    SessionStatus @default(running)
  outcome   SessionOutcome @default(NORMAL)
  amount    Float?
  cancellationReason String?
  canceledAt DateTime?
  billId    Int?

  table Table @relation(fields: [tableId], references: [id])
  bill  Bill? @relation(fields: [billId], references: [id])
  overrideEvents SessionOverrideEvent[]

  @@index([tableId, status])
  @@index([businessDayKey])
  @@map("sessions")
}

model SessionOverrideEvent {
  id           Int      @id @default(autoincrement())
  sessionId    Int
  action       String   @default("override_update")
  changedFields Json?
  beforeData   Json?
  afterData    Json?
  createdAt    DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("session_override_events")
}

model Bill {
  id          Int       @id @default(autoincrement())
  totalAmount Float
  discountType String?
  discountValue Float?
  discountedAmount Float @default(0)
  createdAt   DateTime  @default(now())
  sessions    Session[]
  payments    Payment[]

  @@map("bills")
}

model Payment {
  id      Int         @id @default(autoincrement())
  billId  Int
  mode    PaymentMode
  amount  Float
  createdAt DateTime @default(now())
  dueCustomerName String?
  dueCustomerPhone String?
  dueSettledAt DateTime?
  dueReceivedMode PaymentMode?

  bill Bill @relation(fields: [billId], references: [id])

  @@index([billId])
  @@map("payments")
}

model DailyReport {
  id            Int      @id @default(autoincrement())
  businessDayKey String  @unique
  startAt       DateTime
  endAt         DateTime
  subtotal      Float
  discount      Float
  net           Float
  cash          Float
  upi           Float
  card          Float
  paid          Float
  unpaid        Float
  isBalanced    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessDayKey])
  @@map("daily_reports")
}

model Customer {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  @@index([name])
  @@map("customers")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  pinHash   String
  role      UserRole @default(operator)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@unique([pinHash])
  @@map("users")
}

model AppConfig {
  id                Int      @id @default(autoincrement())
  ledgerResetMinutes Int     @default(600)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("app_config")
}

enum PayerMode {
  none
  single
  split
}

enum SessionStatus {
  running
  completed
  billed
}

enum PaymentMode {
  cash
  upi
  card
  due
}

enum SessionOutcome {
  NORMAL
  LTP_LOSS
  CANCELLED
}

enum UserRole {
  operator
  admin
}
